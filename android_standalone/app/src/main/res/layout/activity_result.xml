<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg">

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:padding="16dp">
        <TextView android:id="@+id/tv_result"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text" android:textSize="13sp"
            android:fontFamily="monospace" android:lineSpacingMultiplier="1.5"
            android:textIsSelectable="true"/>
    </ScrollView>

    <!-- Action buttons -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:background="@color/surface"
        android:padding="12dp">

        <Button android:id="@+id/btn_copy"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📋 Copy"
            android:textColor="@color/text" android:backgroundTint="@color/border"
            android:stateListAnimator="@null"/>

        <Button android:id="@+id/btn_share"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginHorizontal="8dp"
            android:text="↗ Share"
            android:textColor="@color/text" android:backgroundTint="@color/border"
            android:stateListAnimator="@null"/>

        <Button android:id="@+id/btn_save"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="💾 Save"
            android:textColor="#ffffff" android:backgroundTint="@color/accent"
            android:stateListAnimator="@null"/>
    </LinearLayout>

</LinearLayout>
