# Normalize line endings
* text=auto

# Force LF for code files (works on Windows too)
*.py    text eol=lf
*.java  text eol=lf
*.xml   text eol=lf
*.gradle text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.json  text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.ps1   text eol=crlf

# Binary files — no line ending conversion
*.png   binary
*.jpg   binary
*.ico   binary
*.apk   binary
*.exe   binary
*.zip   binary
