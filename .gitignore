# ══════════════════════════════════════════════════════════════════════════
#  .gitignore — Court Defense AI
#  ПРАВИЛО: якщо є сумніви — НЕ комітити.
# ══════════════════════════════════════════════════════════════════════════

# ── КОНФІДЕНЦІЙНІ ДАНІ СПРАВИ ─────────────────────────────────────────────
# Особисті конфігурації, налаштування, API ключі
case_config.py
.env
.env.*
*.env
.launcher_settings.json
*_credentials.json
*_secrets.json
secrets.toml

# ── АУДІО / ВІДЕО / ДОКУМЕНТИ (дані користувача) ─────────────────────────
*.m4a
*.mp3
*.wav
*.flac
*.ogg
*.wma
*.aac
*.opus
*.pdf
*.docx
*.doc
*.zip
*.rar
*.7z

# ── ВИХІДНІ ДАНІ ПАЙПЛАЙНУ (згенерований контент справи) ─────────────────
jobs/
_CourtDefense/
ПАКЕТ_ЗАХИСТУ/
ВІДІБРАНІ_ДОКАЗИ/
Отсортированные_данные_для_суда/
СУДОВІ_ДОКУМЕНТИ/
готовые_нарезки/
нарізки/
нарезки/
data/

# ── ЛОГИ (можуть містити шляхи та зміст файлів справи) ───────────────────
logs/
*.log
processed_files.log
.advocate_cache.json
_raw_analysis.json
DEFENSE_ANALYSIS_FULL.txt

# ── ВЕЛИКІ БІНАРНИКИ (не підходять для git) ───────────────────────────────
ffmpeg/
build/
build_tmp/
*.exe

# ── PYINSTALLER ───────────────────────────────────────────────────────────
# assets/CourtDefense.spec — це конфіг збірки, він КОМІТУЄТЬСЯ
dist/
*.manifest

# ── PYTHON ────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
*.egg-info/
.eggs/
*.whl

# ── СКРИПТИ З ЗАХАРДКОДЖЕНИМИ ОСОБИСТИМИ ШЛЯХАМИ ─────────────────────────
# Містять шляхи типу D:\12314234\ — використовуй scripts/ з env CASE_FOLDER
batch_cut_audio_by_phrases.py
test_audio_cutter_audit.py
QUICK_REFERENCE.txt
BATCH_CUTTER_GUIDE.md
AUDIT_INSTRUCTIONS.md
REFACTORING_COMPLETE.md

# ── ANDROID BUILD ARTIFACTS ──────────────────────────────────────────────
android/.gradle/
android/build/
android/app/build/
android/local.properties
android_standalone/.gradle/
android_standalone/build/
android_standalone/app/build/
android_standalone/local.properties
*.apk
*.aab
*.keystore
*.jks

# ── CLAUDE CODE / IDE / OS ────────────────────────────────────────────────
.claude/
.clineignore
.vscode/
.idea/
*.swp
*.iml
.DS_Store
Thumbs.db
desktop.ini
